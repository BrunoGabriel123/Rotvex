# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_PORT=3000

# Backend
BACKEND_PORT=3001
DATABASE_URL=postgresql://rotvex:rotvex_password@postgres:5432/rotvex
REDIS_URL=redis://:redis_password@redis:6379
JWT_SECRET=your_jwt_secret_here_change_in_production
NODE_ENV=development

# PostgreSQL
POSTGRES_USER=rotvex
POSTGRES_PASSWORD=rotvex_password_change_in_production
POSTGRES_DB=rotvex
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_password_change_in_production
REDIS_PORT=6379

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@rotvex.com
PGADMIN_DEFAULT_PASSWORD=pgadmin_password_change_in_production
PGADMIN_PORT=5050

# Uploads
UPLOAD_DIR=/app/uploads

# Timezone
TZ=America/Sao_Paulo

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
