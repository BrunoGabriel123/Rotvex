# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rotvex?schema=public"

# JWT
JWT_SECRET="your-secret-key-here"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"
JWT_REFRESH_EXPIRATION="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# App
PORT=3001
NODE_ENV="development"

# Swagger
SWAGGER_TITLE="Rotvex API"
SWAGGER_DESCRIPTION="Rotvex - SaaS de gerenciamento logístico"
SWAGGER_VERSION="1.0"
