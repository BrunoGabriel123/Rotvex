// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OperationStatus {
  DRAFT
  AWAITING_PLANNING
  PLANNED
  READY_TO_START
  IN_PICKUP
  IN_TRANSIT
  IN_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum OperationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum OperationStopType {
  PICKUP
  DELIVERY
  SUPPORT
  RETURN
}

enum OperationStopStatus {
  PENDING
  ARRIVED
  IN_SERVICE
  COMPLETED
  FAILED
  SKIPPED
}

model Company {
  id          String    @id @default(cuid())
  name        String
  cnpj        String?   @unique
  active      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]
  clients     Client[]
  vehicles    Vehicle[]
  drivers     Driver[]
  orders      Order[]
  routes      Route[]
  operations  Operation[]
  operationStops OperationStop[]
  operationStatusHistory OperationStatusHistory[]
  operationOccurrences OperationOccurrence[]
  deliveryProofs DeliveryProof[]
  auditLogs   AuditLog[]
  expenses    Expense[]
  notifications Notification[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  name         String
  active       Boolean      @default(true)
  deletedAt    DateTime?
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  roleId       String
  role         Role         @relation(fields: [roleId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]
  createdOperations Operation[] @relation("OperationCreatedBy")
  updatedOperations Operation[] @relation("OperationUpdatedBy")
  statusChanges OperationStatusHistory[] @relation("OperationStatusChangedBy")
  reportedOccurrences OperationOccurrence[] @relation("OperationOccurrenceReportedBy")
  uploadedProofs DeliveryProof[] @relation("DeliveryProofUploadedBy")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  deletedAt   DateTime?
  users       User[]
  rolePermissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id               String            @id @default(cuid())
  name             String            @unique
  description      String?
  resource         String
  action           String
  deletedAt        DateTime?
  rolePermissions  RolePermission[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Vehicle {
  id          String   @id @default(cuid())
  plate       String   @unique
  model       String
  year        Int
  type        String
  status      String   @default("active")
  deletedAt   DateTime?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  maintenances Maintenance[]
  fuels       Fuel[]
  deliveries  Delivery[]
  operations  Operation[]
}

model Driver {
  id          String    @id @default(cuid())
  name        String
  cpf         String?   @unique
  cnh         String?
  cnhType     String?
  phone       String?
  status      String    @default("active")
  deletedAt   DateTime?
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deliveries  Delivery[]
  operations  Operation[]
}

model Client {
  id          String    @id @default(cuid())
  name        String
  cnpj        String?   @unique
  cpf         String?
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  status      String    @default("active")
  deletedAt   DateTime?
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
  operations  Operation[]
  operationStops OperationStop[]
}

model Order {
  id          String    @id @default(cuid())
  orderNumber String    @unique
  description String?
  status      String    @default("pending")
  priority    String    @default("normal")
  deletedAt   DateTime?
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deliveries  Delivery[]
  pickups     Pickup[]
  operations  Operation[]
}

model Delivery {
  id          String   @id @default(cuid())
  status      String   @default("pending")
  address     String
  city        String
  state       String
  zipCode     String
  latitude    Float?
  longitude   Float?
  scheduledAt DateTime?
  completedAt DateTime?
  deletedAt   DateTime?
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  operationId String?
  operation   Operation? @relation(fields: [operationId], references: [id])
  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  driverId    String?
  driver      Driver?  @relation(fields: [driverId], references: [id])
  routeId     String?
  route       Route?   @relation(fields: [routeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pickup {
  id          String   @id @default(cuid())
  status      String   @default("pending")
  address     String
  city        String
  state       String
  zipCode     String
  latitude    Float?
  longitude   Float?
  scheduledAt DateTime?
  completedAt DateTime?
  deletedAt   DateTime?
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  operationId String?
  operation   Operation? @relation(fields: [operationId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Route {
  id          String     @id @default(cuid())
  name        String
  description String?
  status      String     @default("active")
  companyId   String
  deletedAt   DateTime?
  company     Company    @relation(fields: [companyId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deliveries  Delivery[]
  operations  Operation[]
}

model Operation {
  id                   String            @id @default(cuid())
  companyId            String
  company              Company           @relation(fields: [companyId], references: [id])
  clientId             String
  client               Client            @relation(fields: [clientId], references: [id])
  orderId              String?
  order                Order?            @relation(fields: [orderId], references: [id])
  routeId              String?
  route                Route?            @relation(fields: [routeId], references: [id])
  driverId             String?
  driver               Driver?           @relation(fields: [driverId], references: [id])
  vehicleId            String?
  vehicle              Vehicle?          @relation(fields: [vehicleId], references: [id])
  code                 String
  title                String?
  status               OperationStatus
  priority             OperationPriority @default(NORMAL)
  originName           String
  originAddress        String
  originLatitude       Float?
  originLongitude      Float?
  destinationName      String?
  destinationAddress   String?
  destinationLatitude  Float?
  destinationLongitude Float?
  plannedStartAt       DateTime?
  plannedEndAt         DateTime?
  actualStartAt        DateTime?
  actualEndAt          DateTime?
  estimatedDistanceKm  Decimal?          @db.Decimal(10, 2)
  actualDistanceKm     Decimal?          @db.Decimal(10, 2)
  estimatedDurationMin Int?
  actualDurationMin    Int?
  estimatedCost        Decimal?          @db.Decimal(12, 2)
  actualCost           Decimal?          @db.Decimal(12, 2)
  freightValue         Decimal?          @db.Decimal(12, 2)
  quantityTotal        Float?
  volumeTotal          Float?
  weightTotal          Float?
  notes                String?
  cancellationReason   String?
  createdById          String
  createdBy            User              @relation("OperationCreatedBy", fields: [createdById], references: [id])
  updatedById          String?
  updatedBy            User?             @relation("OperationUpdatedBy", fields: [updatedById], references: [id])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  deletedAt            DateTime?
  deliveries           Delivery[]
  pickups              Pickup[]
  stops                OperationStop[]
  statusHistory        OperationStatusHistory[]
  occurrences          OperationOccurrence[]
  proofs               DeliveryProof[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, plannedStartAt])
  @@index([companyId, driverId])
  @@index([companyId, vehicleId])
}

model OperationStop {
  id                 String               @id @default(cuid())
  companyId          String
  company            Company              @relation(fields: [companyId], references: [id])
  operationId        String
  operation          Operation            @relation(fields: [operationId], references: [id])
  clientId           String?
  client             Client?              @relation(fields: [clientId], references: [id])
  sequence           Int
  type               OperationStopType
  status             OperationStopStatus  @default(PENDING)
  locationName       String
  address            String
  latitude           Float?
  longitude          Float?
  windowStartAt      DateTime?
  windowEndAt        DateTime?
  plannedArrivalAt   DateTime?
  actualArrivalAt    DateTime?
  actualDepartureAt  DateTime?
  serviceTimeMinutes Int?
  quantity           Float?
  volume             Float?
  weight             Float?
  notes              String?
  instructions       String?
  contactName        String?
  contactPhone       String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  proofs             DeliveryProof[]
  occurrences        OperationOccurrence[]

  @@index([companyId, operationId])
  @@unique([operationId, sequence])
}

model OperationStatusHistory {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id])
  operationId  String
  operation    Operation        @relation(fields: [operationId], references: [id])
  fromStatus   OperationStatus?
  toStatus     OperationStatus
  changedById  String?
  changedBy    User?            @relation("OperationStatusChangedBy", fields: [changedById], references: [id])
  reason       String?
  metadata     Json?
  createdAt    DateTime         @default(now())

  @@index([companyId, operationId])
  @@index([companyId, toStatus])
}

model OperationOccurrence {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  operationId    String
  operation      Operation     @relation(fields: [operationId], references: [id])
  stopId         String?
  stop           OperationStop? @relation(fields: [stopId], references: [id])
  reportedById   String?
  reportedBy     User?         @relation("OperationOccurrenceReportedBy", fields: [reportedById], references: [id])
  title          String
  description    String?
  severity       String?
  status         String?       @default("open")
  metadata       Json?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId, operationId])
  @@index([companyId, status])
}

model DeliveryProof {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  operationId    String?
  operation      Operation?    @relation(fields: [operationId], references: [id])
  operationStopId String?
  operationStop  OperationStop? @relation(fields: [operationStopId], references: [id])
  uploadedById   String?
  uploadedBy     User?         @relation("DeliveryProofUploadedBy", fields: [uploadedById], references: [id])
  type           String
  url            String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([companyId, operationId])
}

model Maintenance {
  id          String   @id @default(cuid())
  type        String
  description String?
  cost        Float?
  status      String   @default("pending")
  scheduledAt DateTime?
  completedAt DateTime?
  deletedAt   DateTime?
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Fuel {
  id          String   @id @default(cuid())
  liters      Float
  cost        Float
  fuelType    String
  station     String?
  odometer    Int?
  deletedAt   DateTime?
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String
  date        DateTime
  deletedAt   DateTime?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  deletedAt DateTime?
  type      String?
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  read      Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  metadata  Json?
  createdAt DateTime @default(now())
}
